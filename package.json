    "build": "cd client && npx vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-session": "^1.18.0",
    "fast-xml-parser": "^4.3.4",
    "xmlbuilder2": "^3.1.1"
  }
}
